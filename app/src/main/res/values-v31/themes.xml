<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system launch screen now blends into StudyMate's custom splash. -->
    <style name="Theme.StudyMate.Starting" parent="Theme.StudyMate">
        <item name="android:windowSplashScreenBackground">@color/studymate_blue</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:windowSplashScreenAnimationDuration">180</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/white</item>
    </style>
</resources>
